MEDIA_IMAGE_MAX_BYTES=5242880
WECHAT_MINI_APPID=replace_me
WECHAT_MINI_SECRET=replace_me
WECHAT_CODE2SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_LOGIN_TIMEOUT_SECONDS=10
WECHAT_LOGIN_ALLOW_DEV_MOCK=false
WECHAT_PAY_MCH_ID=replace_me
WECHAT_PAY_MERCHANT_SERIAL_NO=replace_me
WECHAT_PAY_PRIVATE_KEY_PATH=/data/watch_shop/certs/apiclient_key.pem
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=/data/watch_shop/certs/wechatpay_public_key.pem
WECHAT_PAY_PLATFORM_SERIAL=replace_me
WECHAT_PAY_API_V3_KEY=replace_me_32_bytes_secret_key
