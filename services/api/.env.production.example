APP_NAME=watch-shop-api
APP_ENV=production
DEBUG=false
API_SECRET_KEY=replace_me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_me
ADMIN_TOKEN_EXPIRE_MINUTES=480
USER_TOKEN_SECRET=replace_user_token_secret
USER_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=mysql+pymysql://watch_shop:replace_me@mysql:3306/watch_shop
SQLALCHEMY_ECHO=false
REDIS_URL=redis://redis:6379/0
API_V1_PREFIX=/api/v1
MEDIA_ROOT=/data/watch_shop/media
